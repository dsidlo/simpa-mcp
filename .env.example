# SIMPA Configuration

# Database
DATABASE_URL=postgresql://dsidlo@localhost:5432/simpa

# Embedding Service
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=

# LLM Service
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_TEMPERATURE=0.7
ANTHROPIC_API_KEY=

# Sigmoid Parameters
SIGMOID_K=1.5
SIGMOID_MU=3.0
MIN_REFINEMENT_PROBABILITY=0.05

# Vector Search
VECTOR_SEARCH_LIMIT=5
VECTOR_SIMILARITY_THRESHOLD=0.7

# MCP Server
MCP_TRANSPORT=stdio
MCP_PORT=8000

# Logging
LOG_LEVEL=INFO
JSON_LOGGING=false

# Security
MAX_PROMPT_LENGTH=10000
ENABLE_PII_DETECTION=true
