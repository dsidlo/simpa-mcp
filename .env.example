# SIMPA Configuration - LiteLLM Compatible
# See: https://docs.litellm.ai/docs/providers for all supported providers

# Database
DATABASE_URL=postgresql://dsidlo@localhost:5432/simpa

# Embedding Service (LiteLLM format: provider/model)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
EMBEDDING_BASE_URL=http://localhost:11434

# LLM Service (LiteLLM format - any provider/model combination)
# Examples:
#   - ollama/llama3.2
#   - openai/gpt-4, openai/gpt-4o
#   - anthropic/claude-3-opus-20240229
#   - azure/gpt-4
#   - gemini/gemini-pro
#   - cohere/command-r
LLM_MODEL=ollama/llama3.2
LLM_TEMPERATURE=0.7

# API Keys (LiteLLM uses these automatically based on model prefix)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
COHERE_API_KEY=
OLLAMA_API_KEY=  # Optional for Ollama

# Sigmoid Parameters
SIGMOID_K=1.5
SIGMOID_MU=3.0
MIN_REFINEMENT_PROBABILITY=0.05

# Vector Search
VECTOR_SEARCH_LIMIT=5
VECTOR_SIMILARITY_THRESHOLD=0.7

# MCP Server
MCP_TRANSPORT=stdio
MCP_PORT=8000

# Logging
LOG_LEVEL=INFO
JSON_LOGGING=false

# Security
MAX_PROMPT_LENGTH=10000
ENABLE_PII_DETECTION=true

# Cache
LLM_CACHE_ENABLED=true
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_CACHE_MAX_SIZE=1000
